# BTG Pactual MFO (Wealth Services) - OAuth2 Client Credentials (BTGWSProvider)
PERSEVERA_BTGWS_CLIENT_ID=
PERSEVERA_BTGWS_CLIENT_SECRET=
# Optional base URLs (defaults: https://api.btgpactual.com/iaas-auth, api-account-base, iaas-api-position)

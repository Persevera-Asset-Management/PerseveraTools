# Database Configuration
PERSEVERA_DB_USER=
PERSEVERA_DB_PASSWORD=
PERSEVERA_DB_HOST=
PERSEVERA_DB_PORT=
PERSEVERA_DB_NAME=

# BTG Pactual Web Platform (RM Admin) - OAuth2 Client Credentials
PERSEVERA_BTG_CLIENT_ID=
PERSEVERA_BTG_CLIENT_SECRET=
PERSEVERA_BTG_ACCOUNT_ID=
# Optional: JWT obtained directly from browser session (valid ~4h, bypasses token endpoint)

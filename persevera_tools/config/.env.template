# ANBIMA Feed API (OAuth2 – https://developers.anbima.com.br/pt/documentacao/visao-geral/autenticacao/)
PERSEVERA_ANBIMA_FEED_CLIENT_ID=
PERSEVERA_ANBIMA_FEED_CLIENT_SECRET=
# Sandbox (default: true). Produção só funciona com acesso liberado pela ANBIMA; use false quando tiver.
PERSEVERA_ANBIMA_FEED_SANDBOX=true
